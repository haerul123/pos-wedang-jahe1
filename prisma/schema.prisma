datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id         Int         @id @default(autoincrement())
  name       String
  base_price Float
  stock_qty  Int
  category   String
  is_active  Boolean     @default(true)
  orderItems OrderItem[]
}

model Order {
  id         Int         @id @default(autoincrement())
  invoice_no String      @unique
  total      Float
  paid       Float
  change     Float
  method     String
  createdAt  DateTime    @default(now())
  items      OrderItem[]
}

model OrderItem {
  id         Int     @id @default(autoincrement())
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId    Int
  product    Product @relation(fields: [productId], references: [id])
  productId  Int
  qty        Int
  note       String?
  subtotal   Float
}

model Ingredient {
  id              Int    @id @default(autoincrement())
  name            String
  stock_kg        Float
  minimum_alert_kg Float
}
